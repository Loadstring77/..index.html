<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>سكربتات - شارك السكربتات بسهولة</title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
    * {
    font-family: 'Cairo', sans-serif;
  }

  body {
    background: #0a0a0f;
    overflow-x: hidden;
  }

 .starfield {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

 .starfield::before,
 .starfield::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image:
      radial-gradient(2px 2px at 20px 30px, rgba(255, 255, 255, 0.8), transparent),
      radial-gradient(2px 2px at 60px 70px, rgba(255, 255, 255, 0.6), transparent),
      radial-gradient(1px 1px at 50px 50px, rgba(255, 255, 255, 0.9), transparent),
      radial-gradient(1px 1px at 130px 80px, rgba(255, 255, 255, 0.7), transparent),
      radial-gradient(2px 2px at 90px 10px, rgba(255, 255, 255, 0.8), transparent);
    background-size: 200px 200px;
    background-position: 0 0;
    animation: stars 60s linear infinite;
  }

 .starfield::after {
    background-image:
      radial-gradient(1px 1px at 40px 60px, rgba(168, 85, 247, 0.8), transparent),
      radial-gradient(1px 1px at 110px 90px, rgba(236, 72, 153, 0.6), transparent),
      radial-gradient(2px 2px at 160px 30px, rgba(251, 146, 60, 0.7), transparent),
      radial-gradient(1px 1px at 70px 120px, rgba(168, 85, 247, 0.5), transparent);
    background-size: 250px 250px;
    animation: stars 100s linear infinite reverse;
  }

  @keyframes stars {
    from { transform: translateY(0); }
    to { transform: translateY(-200px); }
  }

 .glass {
    background: rgba(20, 20, 30, 0.4);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(168, 85, 247, 0.3);
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
  }

 .glass-input {
    background: rgba(30, 30, 45, 0.5);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(168, 85, 247, 0.2);
    transition: all 0.3s ease;
  }

 .glass-input:focus {
    background: rgba(30, 30, 45, 0.7);
    border-color: rgba(168, 85, 247, 0.6);
    box-shadow: 0 0 0 3px rgba(168, 85, 247, 0.1);
    outline: none;
  }

 .gradient-text {
    background: linear-gradient(135deg, #a855f7 0%, #ec4899 50%, #fb923c 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

 .btn-purple {
    background: linear-gradient(135deg, #a855f7 0%, #9333ea 100%);
    transition: all 0.3s ease;
  }
 .btn-purple:hover {
    background: linear-gradient(135deg, #9333ea 0%, #7e22ce 100%);
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -5px rgba(168, 85, 247, 0.4);
  }

 .btn-pink {
    background: linear-gradient(135deg, #ec4899 0%, #db2777 100%);
    transition: all 0.3s ease;
  }
 .btn-pink:hover {
    background: linear-gradient(135deg, #db2777 0%, #be185d 100%);
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -5px rgba(236, 72, 153, 0.4);
  }

 .btn-orange {
    background: linear-gradient(135deg, #fb923c 0%, #f97316 100%);
    transition: all 0.3s ease;
  }
 .btn-orange:hover {
    background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -5px rgba(251, 146, 60, 0.4);
  }

 .btn:active {
    transform: translateY(0);
  }

  textarea::-webkit-scrollbar {
    width: 8px;
  }
  textarea::-webkit-scrollbar-track {
    background: rgba(30, 30, 45, 0.3);
    border-radius: 10px;
  }
  textarea::-webkit-scrollbar-thumb {
    background: rgba(168, 85, 247, 0.5);
    border-radius: 10px;
  }
  textarea::-webkit-scrollbar-thumb:hover {
    background: rgba(168, 85, 247, 0.7);
  }

  @keyframes slideInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
 .toast {
    animation: slideInUp 0.3s ease;
  }
</style>
</head>
<body class="text-gray-100">
  <div class="starfield"></div>

  <div class="relative z-10 min-h-screen py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto">

      <header class="text-center mb-10">
        <div class="flex items-center justify-center gap-3 mb-3">
          <svg class="w-12 h-12 sm:w-14 sm:h-14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="iconGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#a855f7;stop-opacity:1" />
                <stop offset="50%" style="stop-color:#ec4899;stop-opacity:1" />
                <stop offset="100%" style="stop-color:#fb923c;stop-opacity:1" />
              </linearGradient>
            </defs>
            <path d="M14 2L18 6V11.5L16.5 13L18 14.5V20L14 22H10L6 20V14.5L7.5 13L6 11.5V6L10 2H14Z" stroke="url(#iconGradient)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M9 8L7 10L9 12" stroke="url(#iconGradient)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M15 8L17 10L15 12" stroke="url(#iconGradient)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold gradient-text">سكربتات</h1>
        </div>
        <p class="text-gray-400 text-lg sm:text-xl font-medium">شارك السكربتات بسهولة</p>
      </header>

      <div class="glass rounded-3xl p-6 sm:p-8 lg:p-10">

        <div class="mb-6">
          <label for="scriptTitle" class="block text-sm font-semibold text-gray-300 mb-2">العنوان</label>
          <input
            type="text"
            id="scriptTitle"
            placeholder="اكتب عنوان السكربت هنا..."
            class="glass-input w-full px-4 py-3 rounded-xl text-gray-100 placeholder-gray-500 text-right"
          />
        </div>

        <div class="mb-6">
          <label for="scriptContent" class="block text-sm font-semibold text-gray-300 mb-2">السكربت</label>
          <textarea
            id="scriptContent"
            placeholder="الصق أو اكتب السكربت هنا..."
            rows="18"
            class="glass-input w-full px-4 py-3 rounded-xl text-gray-100 placeholder-gray-500 text-right font-mono text-sm resize-none"
            dir="ltr"
          ></textarea>
          <div class="flex justify-between items-center mt-2 px-1">
            <span class="text-xs text-gray-500" id="charCount">0 حرف</span>
            <span class="text-xs text-gray-500" id="lineCount">0 سطر</span>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <button
            id="copyBtn"
            class="btn btn-purple text-white font-semibold py-3.5 px-6 rounded-xl shadow-lg flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
            </svg>
            <span>نسخ السكربت</span>
          </button>

          <button
            id="downloadBtn"
            class="btn btn-pink text-white font-semibold py-3.5 px-6 rounded-xl shadow-lg flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
            </svg>
            <span>تنزيل السكربت</span>
          </button>

          <button
            id="shareBtn"
            class="btn btn-orange text-white font-semibold py-3.5 px-6 rounded-xl shadow-lg flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656l-1.1 1.1"></path>
            </svg>
            <span>نسخ الرابط</span>
          </button>
        </div>
      </div>

      <footer class="text-center mt-8 text-gray-600 text-sm">
        <p>صُنع بـ ❤️ للمبرمجين العرب</p>
      </footer>
    </div>
  </div>

  <div id="toastContainer" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 flex flex-col gap-2"></div>

  <script>
    const titleInput = document.getElementById('scriptTitle');
    const contentInput = document.getElementById('scriptContent');
    const copyBtn = document.getElementById('copyBtn');
    const downloadBtn = document.getElementById('downloadBtn');
    const shareBtn = document.getElementById('shareBtn');
    const charCount = document.getElementById('charCount');
    const lineCount = document.getElementById('lineCount');

    function updateCounts() {
      const content = contentInput.value;
      const chars = content.length;
      const lines = content? content.split('\n').length : 0;
      charCount.textContent = `${chars.toLocaleString('ar-EG')} حرف`;
      lineCount.textContent = `${lines.toLocaleString('ar-EG')} سطر`;
    }

    contentInput.addEventListener('input', updateCounts);

    function showToast(message, type = 'success') {
      const toast = document.createElement('div');
      const bgColor = type === 'success'? 'bg-green-500' : type === 'error'? 'bg-red-500' : 'bg-blue-500';
      toast.className = `toast ${bgColor} text-white px-6 py-3 rounded-xl shadow-2xl font-medium text-sm flex items-center gap-2`;
      toast.innerHTML = `
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
        <span>${message}</span>
      `;
      document.getElementById('toastContainer').appendChild(toast);
      setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transform = 'translateY(10px)';
        setTimeout(() => toast.remove(), 300);
      }, 2500);
    }

    copyBtn.addEventListener('click', async () => {
      const content = contentInput.value.trim();
      if (!content) {
        showToast('لا يوجد سكربت للنسخ', 'error');
        return;
      }
      try {
        await navigator.clipboard.writeText(content);
        showToast('تم نسخ السكربت بنجاح!');
      } catch (err) {
        showToast('فشل النسخ', 'error');
      }
    });

    downloadBtn.addEventListener('click', () => {
      const title = titleInput.value.trim() || 'script';
      const content = contentInput.value.trim();
      if (!content) {
        showToast('لا يوجد سكربت للتنزيل', 'error');
        return;
      }
      const blob = new Blob([content], { type: 'text/plain;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `${title}.txt`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
      showToast('تم بدء التنزيل!');
    });

    shareBtn.addEventListener('click', async () => {
      const title = titleInput.value.trim();
      const content = contentInput.value.trim();
      if (!content &&!title) {
        showToast('لا يوجد محتوى للمشاركة', 'error');
        return;
      }
      try {
        const data = { t: title, c: content };
        const jsonStr = JSON.stringify(data);
        const base64 = btoa(encodeURIComponent(jsonStr));
        const url = `${window.location.origin}${window.location.pathname}?s=${base64}`;
        await navigator.clipboard.writeText(url);
        showToast('تم نسخ رابط المشاركة!');
      } catch (err) {
        showToast('فشل إنشاء الرابط', 'error');
      }
    });

    function loadFromUrl() {
      const params = new URLSearchParams(window.location.search);
      const shared = params.get('s');
      if (shared) {
        try {
          const jsonStr = decodeURIComponent(atob(shared));
          const data = JSON.parse(jsonStr);
          if (data.t) titleInput.value = data.t;
          if (data.c) contentInput.value = data.c;
          updateCounts();
          showToast('تم تحميل السكربت المشارك', 'info');
          window.history.replaceState({}, document.title, window.location.pathname);
        } catch (err) {
          console.error('Failed to load shared script:', err);
        }
      }
    }

    loadFromUrl();
    updateCounts();
  </script>
</body>
</html>
